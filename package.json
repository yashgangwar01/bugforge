{
  "name": "bugforge",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531",
  "scripts": {
    "dev": "pnpm --parallel --filter @bugforge/* dev",
    "build": "pnpm --filter @bugforge/api build && pnpm --filter @bugforge/web build",
    "lint": "pnpm --parallel --filter @bugforge/* lint",
    "typecheck": "pnpm --parallel --filter @bugforge/* typecheck",
    "test": "pnpm --filter @bugforge/api test",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md,yml,yaml}": "prettier --write"
  }
}
