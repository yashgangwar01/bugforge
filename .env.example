# MongoDB credentials — copy this file to .env and fill in real values
# .env is gitignored; .env.example is NOT — never put real secrets here
MONGO_INITDB_ROOT_USERNAME=replace-with-db-username
MONGO_INITDB_ROOT_PASSWORD=replace-with-db-password
# For Atlas: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
# For local Docker: mongodb://replace-with-db-username:replace-with-db-password@mongo:27017/bugforge?authSource=admin
MONGO_URI=replace-with-full-mongo-connection-string
JWT_ACCESS_SECRET=replace-with-a-64-char-random-string
JWT_REFRESH_SECRET=replace-with-a-different-64-char-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# Set in production to restrict CORS to your frontend URL, e.g. https://app.example.com
CORS_ORIGIN=
